		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"preact": "^10.29.2",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	},
	"dependencies": {
		"micromatch": "^4.0.8",
		"nanoid": "^5.1.11",
